# ─── Server Environment Variables ─────────────────────────
DATABASE_URL="libsql://your-db-url.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"
GEMINI_API_KEY="your-gemini-api-key"
ADMIN_PASSWORD="your-admin-dashboard-password"
JWT_SECRET="your-jwt-signing-secret"
PORT=3001

# ─── KiotViet API Credentials ──────────────────────────────
KV_RETAILER="your-kiotviet-retailer"
KV_CLIENT_ID="your-kiotviet-client-id"
KV_CLIENT_SECRET="your-kiotviet-client-secret"
